# Environment Configuration for Saliksik AI
# Copy this file to .env and update values accordingly

# Django Configuration
SECRET_KEY=django-insecure-d514aywbd=gj&#hbflzb5esdrmg@%=(%3e0m*0(@8sb6j-jkh5
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (for production)
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/saliksik_ai

# AI Model Configuration
BART_MODEL_NAME=facebook/bart-large-cnn
SPACY_MODEL=en_core_web_sm

# File Upload Limits
MAX_FILE_SIZE_MB=10
MAX_TEXT_LENGTH=50000

# Cache Configuration (Redis)
CACHE_URL=redis://localhost:6379/1
CACHE_TIMEOUT=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=saliksik_ai.log

# Security Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API Rate Limiting
API_RATE_LIMIT=100/hour
API_BURST_LIMIT=10/minute
