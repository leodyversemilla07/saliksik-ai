# ========================================
# Saliksik AI - Environment Configuration
# ========================================

# Application Settings
# --------------------
PROJECT_NAME=Saliksik AI
VERSION=2.0.0
DEBUG=True

# Database Configuration
# ----------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://saliksik:saliksik123@localhost:5432/saliksik_ai_dev

# Security Settings
# -----------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS Configuration
# ------------------
# Comma-separated or JSON array of allowed origins.
# Comma-separated:  ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# JSON array:       ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]
# No code change needed — update this value and restart the server.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# File Upload Settings
# --------------------
MAX_FILE_SIZE_MB=10

# Rate Limiting
# -------------
RATE_LIMIT_ANON=60/hour
RATE_LIMIT_USER=100/hour

# Redis Cache (Optional)
# ----------------------
# Leave empty to use in-memory cache
# Format: redis://host:port/db_number
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600  # 1 hour in seconds

# Celery Configuration (Optional)
# --------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# AI Model Configuration
# ----------------------
# Set to True to disable heavy models for testing
AI_LIGHT_MODE=False

# PostgreSQL Docker Settings
# --------------------------
# Used by docker-compose.yml
POSTGRES_DB=saliksik_ai
POSTGRES_USER=saliksik
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis Docker Settings
# ---------------------
REDIS_PORT=6379

# Web Server Settings
# -------------------
WEB_PORT=8000

# Logging
# -------
LOG_LEVEL=INFO
